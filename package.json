{
  "name": "maskware",
  "version": "2.0.0",
  "description": "Polymorphic browser fingerprinting protection",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs && web-ext build --source-dir=dist --artifacts-dir=build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "check": "pnpm typecheck && pnpm lint && pnpm test:all",
    "release": "pnpm check && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/chrome": "^0.2.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "web-ext": "^7.11.0"
  },
  "dependencies": {
    "blake3": "^2.1.4",
    "idb": "^8.0.0",
    "preact": "^10.22.0"
  }
}
